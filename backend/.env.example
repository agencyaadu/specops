# --- database (Supabase → Project Settings → Database → Connection string → "Transaction pooler")
DATABASE_URL=postgresql://postgres.xxxxxxxx:YOUR-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# --- supabase storage (Project Settings → API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=submissions
SUPABASE_ATTENDANCE_BUCKET=attendance-photos

# --- google oauth (sign-in on the form)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- app secrets
JWT_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me

# --- attendance tuning
GEO_VERIFY_THRESHOLD_M=200

# --- role seeding (comma-separated; applied on every boot)
# MARSHAL_EMAILS: top-tier admins. Can add/remove other marshals + generals,
#   chiefs, viewers; full read + write across everything.
# GENERAL_EMAILS: second-tier admins. Can add chiefs / viewers and manage
#   operations, but cannot touch marshals or other generals.
# Chiefs + captains are assigned per-operation by a marshal or general.
MARSHAL_EMAILS=
GENERAL_EMAILS=

# --- urls
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
