{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/r/:op_id",       "destination": "/r.html" },
    { "source": "/report",         "destination": "/r.html" },
    { "source": "/report/:op_id",  "destination": "/r.html" },
    { "source": "/ops",         "destination": "/ops.html" },
    { "source": "/ops/general", "destination": "/ops-admin.html" },
    { "source": "/ops/chief",   "destination": "/chief-admin.html" },
    { "source": "/ops/captain",   "destination": "/captain.html" },
    { "source": "/ops/dashboard", "destination": "/dashboard.html" },
    { "source": "/ops/analytics", "destination": "/analytics.html" },
    { "source": "/ops/validate",  "destination": "/validate.html" },
    { "source": "/onboard",     "destination": "/onboard.html" },
    { "source": "/admin",       "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    },
    {
      "source": "/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
