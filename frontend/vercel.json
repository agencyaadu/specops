{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    { "source": "/r/:op_id",  "destination": "/report/:op_id", "permanent": true },
    { "source": "/ops/chief", "destination": "/ops/general",   "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*",    "destination": "https://backend-production-3d2d.up.railway.app/api/:path*" },
    { "source": "/auth/:path*",   "destination": "https://backend-production-3d2d.up.railway.app/auth/:path*" },
    { "source": "/submit",        "destination": "https://backend-production-3d2d.up.railway.app/submit" },
    { "source": "/admin/:path+",  "destination": "https://backend-production-3d2d.up.railway.app/admin/:path+" },
    { "source": "/health",        "destination": "https://backend-production-3d2d.up.railway.app/health" },

    { "source": "/report",           "destination": "/r.html" },
    { "source": "/report/:op_id",    "destination": "/r.html" },
    { "source": "/attendance",       "destination": "/attendance.html" },
    { "source": "/attendance/:op_id","destination": "/attendance.html" },
    { "source": "/ops",         "destination": "/ops.html" },
    { "source": "/ops/general", "destination": "/ops-admin.html" },
    { "source": "/ops/captain",   "destination": "/captain.html" },
    { "source": "/ops/dashboard", "destination": "/dashboard.html" },
    { "source": "/ops/analytics", "destination": "/analytics.html" },
    { "source": "/ops/validate",  "destination": "/validate.html" },
    { "source": "/onboard",     "destination": "/onboard.html" },
    { "source": "/admin",       "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    },
    {
      "source": "/config.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
